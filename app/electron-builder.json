{
  "appId": "com.vedantpanhale.focusguard",
  "productName": "FocusGuard AI",
  "directories": {
    "output": "release"
  },
  "files": [
    "src/**/*",
    "package.json"
  ],
  "win": {
    "target": "nsis",
    "icon": "assets/icons/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  }
}